---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-6xl mb-6 text-gold-400" aria-hidden="true">&#9835;</p>
    <h1 class="font-heading text-4xl font-bold text-primary-900 mb-4">Page Not Found</h1>
    <p class="text-primary-600 mb-8 leading-relaxed">
      Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="px-6 py-3 bg-teal-700 text-white rounded-lg font-medium hover:bg-teal-600 transition-colors"
      >
        Go Home
      </a>
      <a
        href="/contact"
        class="px-6 py-3 bg-primary-200 text-primary-800 rounded-lg font-medium hover:bg-primary-300 transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
