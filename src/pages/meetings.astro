---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout title="Meetings" description="Pittsburgh Recorder Society meeting schedule, location, and what to expect.">
  <section class="max-w-4xl mx-auto px-4 py-12 md:py-16">
    <h1 class="font-heading text-4xl font-bold text-primary-900 mb-2">Meetings</h1>
    <div class="h-px w-24 bg-gold-400 mb-10"></div>

    <!-- Sunday Meetings -->
    <div class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4">Sunday Meetings</h2>
      <div class="bg-white border-2 border-gold-300 rounded-xl p-6">
        <p class="text-lg font-semibold text-primary-900 mb-2">
          3rd Sunday of each month, September through May
        </p>
        <p class="text-primary-700 mb-1">
          <strong>First United Methodist Church of Pittsburgh</strong>
        </p>
        <p class="text-primary-700 mb-4">
          5401 Centre Avenue, Pittsburgh, PA 15232
        </p>
        <div class="space-y-2 text-primary-700 pt-3 border-t border-gold-200">
          <p><strong>2:00 – 3:00 PM</strong> — Beginners and refreshers with Fred Moyes <span class="text-primary-500">(chapel)</span></p>
          <p><strong>2:30 PM</strong> — Technique class with Mike Domain <span class="text-primary-500">(parlor)</span></p>
          <p><strong>3:00 – 5:00 PM</strong> — Group playing, all levels <span class="text-primary-500">(parlor)</span></p>
        </div>
      </div>
    </div>

    <!-- Saturday Sessions -->
    <div class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4">Saturday Sessions</h2>
      <div class="bg-white border border-primary-200 rounded-xl p-6">
        <p class="text-lg font-semibold text-primary-900 mb-2">
          3rd Saturday of each month, September through May
        </p>
        <p class="text-primary-700 mb-1">
          <strong>10:00 AM – 12:00 PM</strong>
        </p>
        <p class="text-primary-700">
          Hosted at a member's home in Allison Park. A more intimate setting for playing together.
          <a href={url('/contact')} class="text-teal-700 hover:text-teal-500 underline decoration-teal-300 underline-offset-2">Contact us</a> for the address and directions.
        </p>
      </div>
    </div>

    <!-- Map -->
    <div class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4">Sunday Location</h2>
      <div class="rounded-lg overflow-hidden border border-primary-200">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3036.5!2d-79.9319!3d40.4527!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8834f22c42a6e5b7%3A0x8e4a6d8e1a7c9e0!2s5401+Centre+Ave%2C+Pittsburgh%2C+PA+15232!5e0!3m2!1sen!2sus!4v1700000000000"
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map showing First United Methodist Church location"
        ></iframe>
      </div>
    </div>

    <!-- What to Expect -->
    <div class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4">What to Expect</h2>
      <p class="text-primary-700 mb-6 leading-relaxed">
        Our meetings are relaxed, welcoming gatherings where recorder players of all
        levels come together to make music. Sunday meetings often have a seasonal theme
        — Celtic tunes for St. Patrick's Day, holiday music in December, and more.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg p-5 border border-primary-200">
          <h3 class="font-heading font-bold text-primary-900 mb-2">Beginners &amp; Refreshers</h3>
          <p class="text-sm text-primary-700 leading-relaxed">
            Fred Moyes works with new and developing players in the chapel on
            fundamentals — tone production, fingering, reading music, and playing
            in a group. Supportive and no-pressure.
          </p>
        </div>
        <div class="bg-white rounded-lg p-5 border border-primary-200">
          <h3 class="font-heading font-bold text-primary-900 mb-2">Technique Class</h3>
          <p class="text-sm text-primary-700 leading-relaxed">
            Mike Domain teaches technique in the parlor starting at 2:30 — a great
            option for players who want to sharpen specific skills.
          </p>
        </div>
        <div class="bg-white rounded-lg p-5 border border-primary-200">
          <h3 class="font-heading font-bold text-primary-900 mb-2">Group Playing</h3>
          <p class="text-sm text-primary-700 leading-relaxed">
            Everyone joins together at 3:00 for the main session — playing a variety
            of pieces from medieval to modern. Music is provided, with parts for all
            levels and instrument sizes.
          </p>
        </div>
      </div>
    </div>

    <!-- What to Bring -->
    <div class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-primary-900 mb-4">What to Bring</h2>
      <ul class="space-y-3 text-primary-700">
        <li class="flex gap-3">
          <span class="text-gold-500 mt-0.5">&#9835;</span>
          <span><strong>Your recorder(s)</strong> — Any size is welcome! Soprano, alto, tenor, bass, and others.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gold-500 mt-0.5">&#9835;</span>
          <span><strong>A music stand</strong> — We have a few extras, but bringing your own is helpful.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-gold-500 mt-0.5">&#9835;</span>
          <span><strong>A pencil</strong> — For marking music.</span>
        </li>
      </ul>
      <p class="mt-4 text-primary-600 text-sm">
        Don't have a recorder yet? <a href={url('/contact')} class="text-teal-700 hover:text-teal-500 underline decoration-teal-300 underline-offset-2">Contact us</a>
        — we can help you get started.
      </p>
    </div>

    <!-- Visitors -->
    <div class="bg-teal-50 border border-teal-200 rounded-xl p-6">
      <h2 class="font-heading text-xl font-bold text-primary-900 mb-3">Visitors Welcome!</h2>
      <p class="text-primary-700 leading-relaxed">
        You're always welcome to visit a meeting before deciding to join. There's no
        obligation — just come and play with us! Annual membership dues are $30
        ($20 for students). Questions? Contact Helen Thornton at
        <a href="mailto:tharphappy@aol.com" class="text-teal-700 hover:text-teal-500 underline decoration-teal-300 underline-offset-2">tharphappy@aol.com</a>
        or call 412-418-3890.
      </p>
    </div>
  </section>
</BaseLayout>
