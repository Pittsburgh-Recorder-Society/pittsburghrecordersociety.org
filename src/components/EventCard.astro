---
interface Props {
  title: string;
  date: Date;
  location?: string;
  description: string;
  slug: string;
}

const { title, date, location, description, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  weekday: 'short',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-white border border-primary-200 rounded-lg p-5 hover:border-gold-400 hover:shadow-md transition-all">
  <time class="text-sm font-medium text-teal-700" datetime={date.toISOString()}>
    {formattedDate}
  </time>
  <h3 class="font-heading text-xl font-bold text-primary-900 mt-1 mb-2">
    <a href={`/events/${slug}`} class="hover:text-teal-700 transition-colors">
      {title}
    </a>
  </h3>
  {location && <p class="text-sm text-primary-500 mb-2">{location}</p>}
  <p class="text-primary-700 line-clamp-2">{description}</p>
  <a
    href={`/events/${slug}`}
    class="inline-block mt-3 text-sm font-medium text-teal-700 hover:text-teal-500 transition-colors"
  >
    Read more &rarr;
  </a>
</article>
