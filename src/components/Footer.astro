---
import { url } from '../utils/url';
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-900 text-primary-200 mt-auto">
  <div class="h-1 bg-gradient-to-r from-gold-500 via-teal-600 to-gold-500"></div>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-heading text-white font-bold mb-3">Pittsburgh Recorder Society</h3>
        <p class="text-sm leading-relaxed">
          A chapter of the American Recorder Society, bringing recorder players together
          in the Pittsburgh area since the 1960s.
        </p>
        <p class="mt-3 font-heading text-gold-400 text-sm italic">"Pastime with good company"</p>
      </div>
      <div>
        <h3 class="font-heading text-white font-bold mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={url('/meetings')} class="hover:text-gold-300 transition-colors">Meeting Schedule</a></li>
          <li><a href={url('/events')} class="hover:text-gold-300 transition-colors">Events</a></li>
          <li><a href={url('/resources')} class="hover:text-gold-300 transition-colors">Resources</a></li>
          <li><a href={url('/contact')} class="hover:text-gold-300 transition-colors">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-heading text-white font-bold mb-3">Connect</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://www.facebook.com/PittsburghRecorderSociety"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-gold-300 transition-colors"
            >
              Facebook
            </a>
          </li>
          <li>
            <a
              href="https://americanrecorder.org"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-gold-300 transition-colors"
            >
              American Recorder Society
            </a>
          </li>
          <li>
            <a
              href="mailto:tharphappy@aol.com"
              class="hover:text-gold-300 transition-colors"
            >
              tharphappy@aol.com
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-primary-700 text-center text-sm text-primary-400">
      <p>&copy; {currentYear} Pittsburgh Recorder Society. All rights reserved.</p>
    </div>
  </div>
</footer>
