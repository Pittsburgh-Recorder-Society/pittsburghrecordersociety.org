---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
}

const { title, description, date } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <header class="mb-10">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-primary-900 mb-3">{title}</h1>
      {date && (
        <time class="text-primary-500 text-sm" datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      <div class="mt-4 h-px bg-gradient-to-r from-gold-400 via-gold-300 to-transparent"></div>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
